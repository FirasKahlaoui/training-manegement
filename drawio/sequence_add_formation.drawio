<mxfile host="app.diagrams.net">
  <diagram id="SequenceAddFormation" name="Add Formation Sequence">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Lifelines -->
        <mxCell id="l_user" value="User (Frontend)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_ctrl" value="FormationController" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="280" y="40" width="120" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_service" value="FormationService" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="110" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_db" value="Database" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="680" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        
        <!-- Messages -->
        <mxCell id="msg1" value="POST /api/formations (formationDTO)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_user" target="l_ctrl">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="130" y="120" as="sourcePoint" />
            <mxPoint x="210" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg2" value="create(formationDTO)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_ctrl" target="l_service">
          <mxGeometry width="80" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="msg3" value="validate() &amp; save(entity)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_service" target="l_db">
          <mxGeometry width="80" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="msg4" value="Saved Data" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_db" target="l_service">
          <mxGeometry width="80" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="msg5" value="Success Response" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_service" target="l_ctrl">
          <mxGeometry width="80" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="msg6" value="201 Created (JSON Object)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_ctrl" target="l_user">
          <mxGeometry width="80" relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
