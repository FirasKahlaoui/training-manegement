<mxfile host="app.diagrams.net">
  <diagram id="SequenceLogin" name="Login Sequence">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Lifelines -->
        <mxCell id="l_user" value="User (Frontend)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_auth" value="AuthController" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="280" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_service" value="AuthService" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        <mxCell id="l_db" value="Database" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="680" y="40" width="100" height="400" as="geometry" />
        </mxCell>
        
        <!-- Messages -->
        <mxCell id="msg1" value="POST /api/auth/login (credentials)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_user" target="l_auth">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="130" y="120" as="sourcePoint" />
            <mxPoint x="210" y="120" as="targetPoint" />
            <Array as="points">
              <mxPoint x="200" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg2" value="authenticate(login, pwd)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_auth" target="l_service">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="330" y="150" as="sourcePoint" />
            <mxPoint x="410" y="150" as="targetPoint" />
            <Array as="points">
              <mxPoint x="400" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg3" value="findByLogin(login)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_service" target="l_db">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="530" y="180" as="sourcePoint" />
            <mxPoint x="610" y="180" as="targetPoint" />
            <Array as="points">
              <mxPoint x="600" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg4" value="User Data" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_db" target="l_service">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="610" y="210" as="sourcePoint" />
            <mxPoint x="530" y="210" as="targetPoint" />
            <Array as="points">
              <mxPoint x="600" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg5" value="generateJWT(user)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1" source="l_service" target="l_service">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="535" y="240" as="sourcePoint" />
            <mxPoint x="535" y="270" as="targetPoint" />
            <Array as="points">
              <mxPoint x="560" y="240" />
              <mxPoint x="560" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg6" value="Token Response (JWT)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_service" target="l_auth">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="410" y="300" as="sourcePoint" />
            <mxPoint x="330" y="300" as="targetPoint" />
            <Array as="points">
              <mxPoint x="400" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg7" value="200 OK (JWT, User Info)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1" source="l_auth" target="l_user">
          <mxGeometry width="80" relative="1" as="geometry">
            <mxPoint x="210" y="330" as="sourcePoint" />
            <mxPoint x="130" y="330" as="targetPoint" />
